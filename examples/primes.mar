int prime(int n)
{
    if(n < 2)
        return 0
    int i = 2
    while(i * i <= n)
    {
        if(n % i == 0)
            return 0
        i = i + 1
    }
    return 1
}

int main()
{
    print("Primes from 2 to 20:\n")
    for i in range(3,1000)
    {
        if(prime(i))
        {
            print("%d ", i)
        }
    }
    print("\n")
    return 0
}
